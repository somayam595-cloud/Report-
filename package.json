{
  "name": "school-program-reports-platform",
  "private": true,
  "version": "2.0.0",
  "description": "منصة عربية ثابتة لإعداد تقارير البرامج المدرسية وحفظها وطباعتها ونشرها على GitHub Pages.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4"
  }
}
